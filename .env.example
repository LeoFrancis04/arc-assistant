# ── Provider ──────────────────────────────────────────────────────────────────
# "anthropic" (cloud) or "ollama" (local)
PROVIDER=anthropic

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Ollama (used when PROVIDER=ollama) ────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Optional tuning ───────────────────────────────────────────────────────────
# MAX_MEMORY_MESSAGES=20   # sliding window size (default: 20)
# DATA_DIR=data            # where memory.json and notes/ are stored
 